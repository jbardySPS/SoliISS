# =============================================================================
#  SOLI-ISS  -  Variables de Entorno
#  Copiar este archivo como .env y completar los valores marcados con <---
#  NUNCA subir el archivo .env al repositorio Git
# =============================================================================

APP_NAME=SoliISS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# Locale
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

# =============================================================================
#  Conexion DB2  -  IBM iSeries Power9
#  Mismos datos que ClubISS, solo cambia DB2_SCHEMA
# =============================================================================
DB_CONNECTION=db2
DB_HOST=10.108.102.42
DB_PORT=446
DB_DATABASE=*LOCAL
DB_USERNAME=jbardy
DB_PASSWORD=                          # <--- completar con la contrasena real

# Schema exclusivo de SOLI-ISS en el iSeries
# Crear con: CRTLIB LIB(SOLIISS) TYPE(*PROD) TEXT('SOLI-ISS Solicitudes ISS')
DB2_SCHEMA=SOLIISS

# Nombre del driver ODBC instalado en Windows
# Verificar nombre exacto en: Panel de Control > Herramientas Admin > ODBC
DB2_DRIVER="iSeries Access ODBC Driver"

# =============================================================================
#  Cache / Session / Queue  (filesystem en v1.0, sin Redis)
# =============================================================================
CACHE_STORE=file
CACHE_PREFIX=soliiss_

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database

# =============================================================================
#  Almacenamiento de adjuntos
#  Ruta en el servidor de archivos ISS donde se guardan los adjuntos
# =============================================================================
FILESYSTEM_DISK=local
ADJUNTOS_MAX_MB=5

# =============================================================================
#  Logs
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
#  Vite (frontend)
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
